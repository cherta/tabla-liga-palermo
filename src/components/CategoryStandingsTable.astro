---
const { rows, results, nextGames, categoryName = 'category' } = Astro.props;

function teamMatches(team) {
  return results.filter((match) => match.home === team || match.away === team);
}

function teamPending(team) {
  return nextGames.filter((match) => match.home === team || match.away === team);
}

function opponentFor(match, team) {
  return match.home === team ? match.away : match.home;
}

function scoreFor(match, team) {
  return match.home === team
    ? `${match.homeGoals} - ${match.awayGoals}`
    : `${match.awayGoals} - ${match.homeGoals}`;
}

function detailId(team, match, index) {
  return `match-detail-${slugify(categoryName)}-${slugify(team)}-${slugify(match.round)}-${index}`;
}

function formatDate(value) {
  if (!value) return null;
  return new Intl.DateTimeFormat('es-UY', { dateStyle: 'medium', timeZone: 'UTC' }).format(new Date(value));
}

function slugify(value) {
  return String(value).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
---

{rows.length ? (
  <div class="team-table">
    <div class="team-table-header" aria-hidden="true">
      <span>Pos</span>
      <span>Equipo</span>
      <span>Pts</span>
      <span>PJ</span>
      <span>Dif</span>
    </div>
    {rows.map((row) => {
      const played = teamMatches(row.team);
      const pending = teamPending(row.team);

      return (
        <details class="team-row">
          <summary>
            <span class="position">{row.position}</span>
            <span class="team-name">{row.team}</span>
            <span class="metric">{row.points}</span>
            <span class="metric">{row.played}</span>
            <span class="metric">{row.goalDifference}</span>
          </summary>

          <div class="team-detail">
            <div class="detail-stats" aria-label={`Estadisticas de ${row.team}`}>
              <span>PG {row.won}</span>
              <span>PE {row.drawn}</span>
              <span>PP {row.lost}</span>
              <span>GF {row.goalsFor}</span>
              <span>GC {row.goalsAgainst}</span>
            </div>

            <section>
              <h4>Jugados</h4>
              {played.length ? (
                <div class="compact-list">
                  {played.map((match, index) => {
                    const details = match.details;
                    const dialogId = detailId(row.team, match, index);
                    const date = details ? formatDate(details.date) : null;

                    return (
                      <>
                        <article class={`compact-match${details ? ' has-detail' : ''}`}>
                          <span>{match.round}</span>
                          <strong>{opponentFor(match, row.team)}</strong>
                          <b>{scoreFor(match, row.team)}</b>
                          {details && (
                            <button
                              class="detail-button"
                              type="button"
                              data-dialog-target={dialogId}
                              aria-label={`Ver detalle de ${match.home} contra ${match.away}`}
                            >
                              i
                            </button>
                          )}
                        </article>

                        {details && (
                          <dialog id={dialogId} class="match-dialog" aria-label={`Detalle de ${match.home} contra ${match.away}`}>
                            <div class="dialog-content">
                              <div class="dialog-header">
                                <div>
                                  <p class="eyebrow">{match.round}</p>
                                  <h3 class="dialog-scoreline">
                                    <span>{match.home}</span>
                                    <b><span>{match.homeGoals}</span> - <span>{match.awayGoals}</span></b>
                                    <span>{match.away}</span>
                                  </h3>
                                </div>
                                <form method="dialog">
                                  <button class="dialog-close" type="submit" aria-label="Cerrar detalle">×</button>
                                </form>
                              </div>

                              {(date || details.venue) && (
                                <div class="dialog-meta">
                                  {date && <span>{date}</span>}
                                  {details.venue && <span>Cancha: {details.venue}</span>}
                                </div>
                              )}

                              <section>
                                <h4>Goles de {details.sourceTeam}</h4>
                                {details.goals?.length ? (
                                  <ul class="scorer-list">
                                    {details.goals.map((goal) => (
                                      <li>
                                        <strong>{goal.player}</strong>
                                        <span aria-label={`${goal.goals} ${goal.goals === 1 ? 'gol' : 'goles'}`}>{'⚽'.repeat(goal.goals)}</span>
                                      </li>
                                    ))}
                                  </ul>
                                ) : (
                                  <p class="empty small">Sin detalle de goleadores.</p>
                                )}
                              </section>

                              {details.note && <p class="match-note">{details.note}</p>}
                            </div>
                          </dialog>
                        )}
                      </>
                    );
                  })}
                </div>
              ) : (
                <p class="empty small">Sin partidos jugados.</p>
              )}
            </section>

            <section>
              <h4>Próximos cruces posibles</h4>
              {pending.length ? (
                <div class="compact-list pending-list">
                  {pending.map((match) => (
                    <article class="compact-match">
                      <span>vs</span>
                      <strong>{opponentFor(match, row.team)}</strong>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="empty small">Sin cruces pendientes inferidos.</p>
              )}
            </section>
          </div>
        </details>
      );
    })}
  </div>
) : (
  <p class="empty">No hay tabla disponible.</p>
)}
