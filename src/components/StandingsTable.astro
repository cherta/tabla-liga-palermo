---
const { rows } = Astro.props;
---

{rows.length ? (
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Pos</th>
          <th>Equipo</th>
          <th>Pts</th>
          <th>PJ</th>
          <th>Dif</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td>{row.position}</td>
            <td>{row.team}</td>
            <td>{row.points}</td>
            <td>{row.played}</td>
            <td>{row.goalDifference}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
) : (
  <p class="empty">No hay tabla disponible.</p>
)}
